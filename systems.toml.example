# kdive live-test systems descriptor (EXAMPLE).
#
# Copy to `systems.toml` (repo root, GITIGNORED) and fill in the values for your environment.
# One source of truth for the per-deployment facts the live MCP coverage-campaign rerun
# otherwise re-derives by hand each run (remote host FQDN/IP, k8s namespace + forward ports,
# the workstation LAN IP remote guests must reach, TLS secret refs).
#
# Consumed by scripts/coverage_campaign/systems.py:
#   uv run python -m scripts.coverage_campaign.systems render-env      -> the d1.env workstation env
#   uv run python -m scripts.coverage_campaign.systems setup-commands  -> remote iptables ACL + k8s port-forwards
#
# See docs/runbooks/mcp-coverage-campaign-rerun.md and
# docs/reports/provider-configuration-requirements.md.

schema_version = 1

[workstation]              # D1 — control plane: Docker app-tier + local-libvirt provider
lan_ip = "<workstation-lan-ip>"                  # reachable FROM remote guests (F8)
s3_endpoint_url = "http://<workstation-lan-ip>:9000"
secrets_root = "$HOME/.kdive-secrets"            # use $HOME, not ~ (tilde does not expand in quotes)
fault_inject = true
mcp_base_url = "http://127.0.0.1:8000/mcp"
build_workspace = "<repo>/.live-build"           # absolute (zsh-source guard)
build_component_roots = "<repo>/fixtures/local-libvirt:<repo>/.live-components"

[remote_libvirt]           # ub24-big — qemu+tls libvirt host
host_fqdn = "<remote-host-fqdn>"
host_ip = "<remote-host-ip>"
ssh_target = "<user>@<remote-host-fqdn>"          # the login user + FQDN, e.g. dave@host.example
libvirt_uri = "qemu+tls://<remote-host-fqdn>/system"
tls_port = 16514
gdbstub_range = "47000:47099"
gdb_addr = "<remote-host-ip>"
base_image_volume = "fedora-kdive-remote-base-43.qcow2"
client_cert_ref = "remote-clientcert.pem"
client_key_ref = "remote-clientkey.pem"           # pragma: allowlist secret - filename ref
ca_cert_ref = "remote-ca.pem"
acl_source_ip = "<workstation-lan-ip>"            # host ACL for off-design workstation drive

[k8s]                      # D2 — kdive deployed via the chart
context = "<kube-context>"
namespace = "<namespace>"
helm_release = "kdive"
fault_inject = true
oidc_forward = "svc/kdive-kdive-oidc"
oidc_service_port = 8080
oidc_local_port = 8080
server_forward = "svc/kdive-kdive-server"
server_service_port = 8000
server_local_port = 18000
in_cluster_issuer = "http://kdive-kdive-oidc:8080/default"
