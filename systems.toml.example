# kdive systems inventory descriptor (EXAMPLE) — schema v2 (ADR-0112).
#
# Copy to `systems.toml` (repo root, GITIGNORED) and fill in your environment. This is the single
# declarative source of truth for the inventory the app loads into the database:
#
#   * `[[image]]`           -> reconciled into `image_catalog` (replaces the former in-code
#                             `images/seed_data/*.yaml` + `admin/default_fixtures.py` rootfs YAML
#                             and the `REMOTE_BASE_IMAGE_NAME` literal — all removed in Phase 1).
#   * `[[remote_libvirt]]` / `[[local_libvirt]]` / `[[fault_inject]]` / `[[build_host]]`
#                           -> reconciled into `resources` / `build_hosts` (Phases 2-3).
#
# Load it with `kdive reconcile-systems` (or the deploy `migrate` step, or the reconciler loop).
# Path is `KDIVE_SYSTEMS_TOML` (default `./systems.toml`; in k8s a mounted ConfigMap).
# Operational/secret config stays in the `KDIVE_*` env registry (ADR-0087) — this file holds
# secret *refs* (filenames the SecretRegistry resolves), never secret material.
#
# NOTE: the coverage-campaign tooling (`scripts/coverage_campaign/systems.py`,
# `render-env`/`setup-commands`) reads the pre-v2 descriptor format. Its migration to this v2
# schema is Phase 3 (#394); until then run the campaign against its own pre-v2 descriptor.

schema_version = 2

# ---------------------------------------------------------------------------------------------
# IMAGES — reconciled into image_catalog. `source` is exactly one of s3 | build | staged.
# ---------------------------------------------------------------------------------------------

# The kdive-ready local baseline rootfs (the former seed_data baseline). Declared `s3`; it
# reaches `registered` once its object is published and a `digest` is supplied — until then it
# stays `defined` (the same pre-build state the old YAML seed produced).
[[image]]
provider = "local-libvirt"
name = "fedora-kdive-ready-43"
arch = "x86_64"
format = "qcow2"
root_device = "/dev/vda"
visibility = "public"
capabilities = ["kdive-ready-console", "ssh", "drgn"]
[image.source]
kind = "s3"
object_key = "rootfs/local/fedora-kdive-ready-43.qcow2"
# digest = "sha256:…"   # uncomment once published to mark the row `registered`

[[image]]
provider = "local-libvirt"
name = "fedora-cloud-43"
arch = "x86_64"
format = "qcow2"
root_device = "/dev/vda"
visibility = "public"
capabilities = ["cloud-init", "ssh"]
[image.source]
kind = "s3"
object_key = "rootfs/local/fedora-cloud-43.qcow2"

[[image]]
provider = "local-libvirt"
name = "busybox-bare"
arch = "x86_64"
format = "qcow2"
root_device = "/dev/vda"
visibility = "public"
capabilities = ["console", "busybox"]
[image.source]
kind = "s3"
object_key = "rootfs/local/busybox-bare.qcow2"

# The remote-libvirt provisioning base image (the former REMOTE_BASE_IMAGE_NAME literal). It is
# an operator-staged libvirt volume, so it is `staged` (no S3 object) and registers immediately.
[[image]]
provider = "remote-libvirt"
name = "fedora-kdive-remote-base-43"
arch = "x86_64"
format = "qcow2"
root_device = "/dev/vda"
visibility = "public"
[image.source]
kind = "staged"
volume = "fedora-kdive-remote-base-43.qcow2"

# ---------------------------------------------------------------------------------------------
# PROVIDER INSTANCES — reconciled into resources (Phase 2-3; shown here for reference).
# ---------------------------------------------------------------------------------------------

# [[remote_libvirt]]
# name = "ub24-big"
# uri = "qemu+tls://ub24-big.example/system"
# gdb_addr = "192.168.10.20"
# gdbstub_range = "47000:47099"
# client_cert_ref = "remote-clientcert.pem"
# client_key_ref = "remote-clientkey.pem"   # pragma: allowlist secret - filename ref
# ca_cert_ref = "remote-ca.pem"
# base_image = "fedora-kdive-remote-base-43"   # -> an [[image]] name
# cost_class = "remote"
# concurrent_allocation_cap = 1
# shapes = ["small", "medium", "large", "max"]

# [[local_libvirt]]
# name = "workstation"
# host_uri = "qemu:///system"
# cost_class = "local"
# concurrent_allocation_cap = 1

# Fault-inject (the synthetic, hardware-free provider) is now created ONLY from this file
# (Phase 2, #393): reconcile_resources is its sole creator and the vcpus/memory_mb below are
# the billable sizing the row advertises to admission — without them allocations.request(
# kind=fault-inject) is denied configuration_error (#385). Uncomment to make it allocatable.
# Array-of-tables = multiple instances (Phase 3, #394): declare as many [[fault_inject]] blocks
# as you need; they share the synthetic host_uri (fault-inject://local) and coexist via the
# (kind, name) identity, each an independently allocatable resource.
# [[fault_inject]]
# name = "synthetic-1"
# cost_class = "local"
# concurrent_allocation_cap = 1
# vcpus = 8
# memory_mb = 8192
# seed = 1337
# [[fault_inject]]
# name = "synthetic-2"
# cost_class = "local"
# concurrent_allocation_cap = 1
# vcpus = 16
# memory_mb = 16384
# seed = 7331

# ---------------------------------------------------------------------------------------------
# BUILD HOSTS — reconciled into build_hosts (Phase 3, #394).
# ---------------------------------------------------------------------------------------------
#
# Only `local` and `ephemeral_libvirt` hosts are config-expressible: the v2 [[build_host]] model
# carries no address/ssh_credential_ref, so an `ssh` host is registered imperatively via
# `build_hosts.register` (which carries those fields) and is warned-and-skipped if declared here.
# An `ephemeral_libvirt` host requires `base_image_volume`; a `local` host must omit it.
# Declaring the seeded `worker-local` row here ADOPTS it (flips managed_by runtime -> config).

# [[build_host]]
# name = "ub24-big-ephemeral"
# kind = "ephemeral_libvirt"
# base_image_volume = "fedora-kdive-remote-base-43.qcow2"
# workspace_root = "/var/lib/kdive/build"
# max_concurrent = 2
